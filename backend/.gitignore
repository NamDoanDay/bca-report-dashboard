# Chặn thư mục cài đặt thư viện (Cực kỳ nặng, không được push)
node_modules/

# Chặn file lưu biến môi trường (Chứa mật khẩu Database root, rất nguy hiểm nếu lộ)
.env

# Chặn các file log hệ thống khi ứng dụng gặp lỗi
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Chặn thư mục logs phục vụ phát triển
logs/
*.log

# Chặn file cấu hình tùy biến của một số môi trường chạy local
.env
.env.local
.env.development.local
.env.test.local
.env.production.local